# ============================================================
# SUPER MONSTER ZERO — Node.js Server Environment
# Copy to .env and fill in your values
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ── Security (CHANGE THESE!) ─────────────────────────────────
SESSION_SECRET=change_me_to_a_random_64_char_string
ADMIN_PASSWORD=changeme

# ── Agent Zero Backend ────────────────────────────────────────
# Local: http://localhost:55080
# Docker: http://super-monster-zero:80
AGENT_ZERO_URL=http://localhost:55080
AGENT_ZERO_WS=ws://localhost:55080

# ── Hostinger Deployment (filled automatically by CI) ─────────
# HOSTINGER_HOST=srv123456789.hstgr.cloud
# HOSTINGER_USER=u123456789
# HOSTINGER_SSH_KEY=  (set as GitHub Secret)
